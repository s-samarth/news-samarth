# Twitter/X (Playwright-based extraction)
# Use a burner account - credentials stored in isolated browser profile
TWITTER_USERNAME=your_burner_username
TWITTER_PASSWORD=your_burner_password
TWITTER_EMAIL=your_email_for_verification  # Optional, for verification screens

# AI Summarization (OpenRouter - https://openrouter.ai/)
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Model to use for summarization (see https://openrouter.ai/models for options)
# Recommended: anthropic/claude-3.5-sonnet, openai/gpt-4o, meta-llama/llama-3.1-70b-instruct
OPENROUTER_MODEL=openrouter/hunter-alpha

# Newsletter Generation (AI Agent-based)
# Model for newsletter generation (can be same or different from summarization)
NEWSLETTER_MODEL=openrouter/hunter-alpha
# Top N articles to include in newsletter (default: 20)
NEWSLETTER_TOP_N=20

# Timezone Configuration
# Default: 'local' (uses system timezone)
# Can be set to any valid timezone string (e.g., 'UTC', 'America/New_York', 'Asia/Kolkata')
TIMEZONE=local

# Database Cleanup Configuration
# Enable automatic cleanup of old articles (default: false)
AUTO_CLEANUP_ENABLED=false
# Number of days to keep articles (default: 30)
AUTO_CLEANUP_DAYS=30
# Run cleanup on server startup (default: false)
AUTO_CLEANUP_ON_STARTUP=false
