# Twitter / twscrape — accounts managed via `twscrape` CLI, no env vars needed

# AI Summarization (OpenRouter - https://openrouter.ai/)
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Model to use for summarization (see https://openrouter.ai/models for options)
# Recommended: anthropic/claude-3.5-sonnet, openai/gpt-4o, meta-llama/llama-3.1-70b-instruct
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Newsletter Generation (AI Agent-based)
# Model for newsletter generation (can be same or different from summarization)
NEWSLETTER_MODEL=anthropic/claude-3.5-sonnet
# Top N articles to include in newsletter (default: 20)
NEWSLETTER_TOP_N=20
